datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

model UserProfile {
  id           Int      @id @default(autoincrement())
  mail         String   @unique
  username     String?  @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")
  lifeCycleStatus LifeCycleStatus @map("life_cycle_status")

  role   Role @relation(fields: [roleId], references: [id])
  roleId Int  @map("role_id")

  scoutProfile ScoutProfile?

  @@map("user_profiles")
}

model ScoutProfile {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  lastName  String   @map("last_name")
  firstName String   @map("first_name")
  phone     String?
  address   String
  dob       DateTime
  citizenId String   @unique @map("citizen_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  lifeCycleStatus LifeCycleStatus @map("life_cycle_status")
  section Section @map("section")

  userProfile   UserProfile @relation(fields: [userProfileId], references: [id])
  userProfileId Int         @unique @map("user_profile_id")

  profileDetails ProfileDetail[]
  camps Camp[]
  weeklyAttendances      WeeklyAttendance[] @relation("ScoutWeeklyAttendances")
  approvedWeeklyAttendances      WeeklyAttendance[] @relation("ApprovedWeeklyAttendances")
  challengeRecords ChallengeRecord[] @relation("ScoutChallengeRecords")
  approvedChallengeRecords ChallengeRecord[] @relation("ApprovedChallengeRecords")
  seasonRecords SeasonRecord[] @relation("ScoutSeasonRecords")
  approvedSeasonRecords SeasonRecord[] @relation("ApprovedSeasonRecords")
  campAttendances CampAttendance[] @relation("ScoutCampAttendances")
  approvedCampAttendances CampAttendance[] @relation("ApprovedCampAttendances")
  campExpenses CampExpense[] @relation("ScoutCampExpenses")
  approvedCampExpenses CampExpense[] @relation("ApprovedCampExpenses")

  @@map("scout_profiles")
}

model ProfileDetail {
  id          Int      @id @default(autoincrement())
  imageUrl    String?  @map("image_url")
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  lifeCycleStatus LifeCycleStatus @map("life_cycle_status")
  profileDetailType ProfileDetailType @map("type")

  scoutProfile   ScoutProfile @relation(fields: [scoutProfileId], references: [id])
  scoutProfileId Int          @map("scout_profile_id")

  achievement   Achievement @relation(fields: [achievementId], references: [id])
  achievementId Int         @map("achievement_id")

  unit   Unit @relation(fields: [unitId], references: [id])
  unitId Int  @map("unit_id")

  @@map("profile_details")
}

model Achievement {
  id          Int      @id @default(autoincrement())
  title       String
  description String?  @db.Text
  imageUrl    String?  @map("image_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  lifeCycleStatus LifeCycleStatus @map("life_cycle_status")
  achievementType AchievementType @map("type")
  section Section @map("section")

  profileDetails ProfileDetail[]
  challenges     Challenge[]

  @@map("achievements")
}

model Unit {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(50)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  lifeCycleStatus LifeCycleStatus @map("life_cycle_status")
  section Section? @map("section")
  unitType UnitType @map("unit_type")

  parentId      Int?
  parent        Unit?  @relation("GroupUnits", fields: [parentId], references: [id])
  children Unit[] @relation("GroupUnits")

  profileDetails ProfileDetail[]
  seasons       Season[]

  @@map("units")
}

model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  lifeCycleStatus LifeCycleStatus @map("life_cycle_status")

  roles Role[]

  @@map("permissions")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  lifeCycleStatus LifeCycleStatus @map("life_cycle_status")

  permissions   Permission[]
  userProfiles UserProfile[]

  @@map("roles")
}

model WeeklyAttendance {
  id        Int      @id @default(autoincrement())
  date      DateTime
  isPresent Boolean  @default(false) @map("is_present")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  approvalStatus ApprovalStatus @map("approval_status")

  scoutProfile   ScoutProfile @relation("ScoutWeeklyAttendances", fields: [scoutProfileId], references: [id])
  scoutProfileId Int          @map("attendee_id")

  approver   ScoutProfile @relation("ApprovedWeeklyAttendances", fields: [approverId], references: [id])
  approverId Int          @map("approved_by_id")

  @@unique([date, scoutProfileId])

  @@map("weekly_attendances")
}

model Season {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  description String?  @db.Text
  imageUrl    String?  @map("image_url")
  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  lifeCycleStatus LifeCycleStatus @map("life_cycle_status")

  unit Unit @relation(fields: [unitId], references: [id])
  unitId Int @map("unit_id")

  contests Contest[]

  @@map("seasons")
}

model SeasonRecord {
  id          Int      @id @default(autoincrement())
  countInSeason Int @map("count_in_season")
  actualPoint Float @map("actual_point")
  overallPlace       Int? @map("ovr_place")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  approvalStatus ApprovalStatus @map("approval_status")

  contest Contest @relation(fields: [contestId], references: [id])
  contestId Int @map("contest_id")

  scoutProfile ScoutProfile @relation("ScoutSeasonRecords", fields: [scoutProfileId], references: [id])
  scoutProfileId Int @map("scout_profile_id")

  approver ScoutProfile? @relation("ApprovedSeasonRecords", fields: [approverId], references: [id])
  approverId Int? @map("approved_by_id")

@@unique([contestId, scoutProfileId])

  @@map("season_records")
}

model Contest {
  id          Int      @id @default(autoincrement())
  name        String
  description String?  @db.Text
  imageUrl    String?  @map("image_url")
  countInSeason Int @map("count_in_season")
  point Float
  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  lifeCycleStatus LifeCycleStatus @map("life_cycle_status")
  contestFormat ContestFormat @map("contest_format")
  contestType ContestType @map("contest_type")

  season Season @relation(fields: [seasonId], references: [id])
  seasonId Int @map("season_id")

  challenges Challenge[]
  seasonRecords SeasonRecord[]

  @@unique([name, seasonId])
  @@map("contests")
}

model Challenge {
  id          Int      @id @default(autoincrement())
  description String  @db.Text
  imageUrl    String?  @map("image_url")
  pointWeight Float @map("point_weight")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  lifeCycleStatus LifeCycleStatus @map("life_cycle_status")

  contest Contest @relation(fields: [contestId], references: [id])
  contestId Int @map("contest_id")

  rank Achievement? @relation(fields: [rankId], references: [id])
  rankId Int? @map("rank_id")

  challengeRecords ChallengeRecord[]

  @@map("challenges")
}

model ChallengeRecord {
  id          Int      @id @default(autoincrement())
  proofUrl    String?  @map("proof_url")
  comment     String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  approvalStatus ApprovalStatus @map("approval_status")

  challenge Challenge @relation(fields: [challengeId], references: [id])
  challengeId Int @map("challenge_id")

  scoutProfile ScoutProfile @relation("ScoutChallengeRecords", fields: [scoutProfileId], references: [id])
  scoutProfileId Int @map("scout_profile_id")

  approver ScoutProfile? @relation("ApprovedChallengeRecords", fields: [approverId], references: [id])
  approverId Int? @map("approved_by_id")

  @@unique([challengeId, scoutProfileId])

  @@map("challenge_records")
}

model Camp {
  id          Int      @id @default(autoincrement())
  name        String
  description String?  @db.Text
  imageUrl    String?  @map("image_url")
  location String
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  dayCount Int @map("day_count")
  nightCount Int @map("night_count")
  transportationCutOff Int @map("transportation_cut_off")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  approvalStatus ApprovalStatus @map("approval_status")

  leader ScoutProfile @relation(fields: [leaderId], references: [id])
  leaderId Int @map("leader_id")

  campFees CampFee[]
  campAttendances CampAttendance[]
  campExpenses CampExpense[]

  @@map("camps")
}

model CampFee {
  id          Int      @id @default(autoincrement())
  amount      Int
  dueDate     DateTime @map("due_date")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  approvalStatus ApprovalStatus @map("approval_status")
  section Section @map("section")

  camp Camp @relation(fields: [campId], references: [id])
  campId Int @map("camp_id")

  @@map("camp_fees")
}

model CampAttendance {
  id          Int      @id @default(autoincrement())
  isIndependent Boolean  @default(false) @map("is_independent")
  actualFee Int @map("actual_fee")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  campAttendanceStatus CampAttendanceStatus @map("camp_attendance_status")
  paymentMethod PaymentMethod @map("payment_method")
  paymentStatus PaymentStatus @map("payment_status")

  camp Camp @relation(fields: [campId], references: [id])
  campId Int @map("camp_id")

  scoutProfile ScoutProfile @relation("ScoutCampAttendances", fields: [scoutProfileId], references: [id])
  scoutProfileId Int @map("attendee_id")

  approver   ScoutProfile @relation("ApprovedCampAttendances", fields: [approverId], references: [id])
  approverId Int          @map("approved_by_id")

  campTransaction CampTransaction?

  @@map("camp_attendance")
}

model CampTransaction {
  id          Int      @id @default(autoincrement())
  amount      Int
  note String?  @db.Text
  transactionDate DateTime @map("transaction_date")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  paymentMethod PaymentMethod @map("payment_method")
  paymentStatus PaymentStatus @map("payment_status")

  campAttendance CampAttendance? @relation(fields: [campAttendanceId], references: [id])
  campAttendanceId Int? @unique @map("camp_attendance_id")

  campExpense CampExpense? @relation(fields: [campExpenseId], references: [id])
  campExpenseId Int? @unique @map("camp_expense_id")

  @@map("camp_transactions")
}

model CampExpense {
  id          Int      @id @default(autoincrement())
  amount      Int
  reason String?  @db.Text
  expenseDate DateTime @map("expense_date")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  paymentMethod PaymentMethod @map("payment_method")
  paymentStatus PaymentStatus @map("payment_status")

  camp Camp @relation(fields: [campId], references: [id])
  campId Int @map("camp_id")

  scoutProfile ScoutProfile @relation("ScoutCampExpenses", fields: [scoutProfileId], references: [id])
  scoutProfileId Int @map("attendee_id")

  approver   ScoutProfile @relation("ApprovedCampExpenses", fields: [approverId], references: [id])
  approverId Int          @map("approved_by_id")

  campTransaction CampTransaction?

  @@map("camp_expenses")
}

enum PaymentMethod {
  CASH
  ONLINE
}

enum PaymentStatus {
  PENDING
  REGISTERED
  PAID
  OVERDUE
}

enum CampAttendanceStatus {
  UPCOMING
  ATTENDED
  MISSED
}

enum ApprovalStatus {
  DRAFT
  APPROVED
  REJECTED
}

enum LifeCycleStatus {
  UPCOMING
  ACTIVE
  INACTIVE
  DELETED
}

enum Section {
  BEAVER
  CUB
  SCOUT
  VENTURER
  ROVER
  LEADER
  PARENT
}

enum UnitType {
  DISTRICT
  TROOP
  GROUP
}

enum AchievementType {
  BADGE
  RANK
}

enum ContestFormat {
  INDIVIDUAL
  TEAM
}

enum ContestType {
  WEEKLY
  CAMP
  OUTING
}

enum ProfileDetailType {
  ACHIEVEMENT
  UNIT
}
